# Supabase (Project Settings → API Keys — use publishable + secret keys, not legacy anon/service_role)
# NEXT_PUBLIC_* are safe for the browser; never put the secret key in client code.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only: sync / admin operations only; never expose to the client or NEXT_PUBLIC_*
SUPABASE_SECRET_KEY=sb_secret_...

# Notion integration (Internal Integration token)
NOTION_TOKEN=secret_...

# Single Tasks database (FR-4 PRD)
NOTION_TASKS_DATABASE_ID=

# People property on tasks linking guests (PRD §6.1)
NOTION_KLANTV2_PROPERTY=KlantV2
