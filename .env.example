# Supabase (Project Settings → API)
# NEXT_PUBLIC_* are safe for the browser; never put the service role in client code.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: sync / admin operations only; never expose to the client or NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Notion integration (Internal Integration token)
NOTION_TOKEN=secret_...

# Single Tasks database (FR-4 PRD)
NOTION_TASKS_DATABASE_ID=

# People property on tasks linking guests (PRD §6.1)
NOTION_KLANTV2_PROPERTY=KlantV2
